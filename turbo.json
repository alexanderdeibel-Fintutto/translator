{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.json", "tailwind.config.js"],
  "tasks": {
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"],
      "env": [
        "VITE_GOOGLE_TTS_API_KEY",
        "VITE_GA_MEASUREMENT_ID",
        "VITE_SENTRY_DSN",
        "VITE_SUPABASE_URL",
        "VITE_SUPABASE_ANON_KEY",
        "VITE_STRIPE_PUBLISHABLE_KEY",
        "VITE_AZURE_TRANSLATE_KEY",
        "VITE_ADMIN_API_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [],
      "outputs": []
    }
  }
}
