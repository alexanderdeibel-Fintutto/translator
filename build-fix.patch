+// Helper to get other apps in the ecosystem (for footers, cross-sell, etc.)
+export function getOtherApps(currentAppSlug: string) {
+  return Object.entries(FINTUTTO_APPS)
+    .filter(([, app]) => app.slug !== currentAppSlug && 'url' in app && app.url)
+    .map(([key, app]) => ({
+      key,
+      name: app.name,
+      slug: app.slug,
+      description: app.description,
+      icon: app.icon,
+      url: (app as any).url as string,
+      category: app.category,
+    }))
+}
