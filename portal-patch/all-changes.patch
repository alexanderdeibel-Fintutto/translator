+            {error || "Keine Kartenvorschau verfuegbar"}
+          </p>
+          {showLink && (
+            <a
+              href={googleMapsUrl}
+              target="_blank"
+              rel="noopener noreferrer"
+              className="mt-2 text-xs text-primary hover:underline flex items-center gap-1"
+            >
+              <ExternalLink className="h-3 w-3" />
+              In Google Maps oeffnen
+            </a>
+          )}
+        </div>
+      )}
+    </div>
+  );
+}
