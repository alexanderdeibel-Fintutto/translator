# =============================================================================
# CLIENT-SIDE VARIABLES (VITE_ prefix — bundled into the app, visible to users)
# =============================================================================

# Google Cloud API Key (shared for TTS, Translate, and STT)
# Get yours at: https://console.cloud.google.com/apis/credentials
#
# Enable these APIs in Google Cloud Console:
# - Cloud Text-to-Speech API:  https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# - Cloud Translation API:     https://console.cloud.google.com/apis/library/translate.googleapis.com
# - Cloud Speech-to-Text API:  https://console.cloud.google.com/apis/library/speech.googleapis.com
#
# Free tiers:
# - TTS: 1 Mio Zeichen/Monat (Standard), 100k Zeichen/Monat (Neural2/WaveNet)
# - STT: 60 Minuten/Monat (wird fuer iOS-Spracheingabe benoetigt)
VITE_GOOGLE_TTS_API_KEY=

# --- Analytics & Monitoring ---

# Google Analytics 4 — Measurement ID
# Create at: https://analytics.google.com → Admin → Data Streams → Web
VITE_GA_MEASUREMENT_ID=

# Sentry — Error Tracking DSN
# Create at: https://sentry.io → Projects → Create Project → Browser JavaScript
VITE_SENTRY_DSN=

# --- Admin Dashboard ---

# API endpoint for the fintutto admin dashboard
# All events, errors, and metrics are batched and sent here
VITE_ADMIN_API_URL=

# API key for authenticating with the admin dashboard
VITE_ADMIN_API_KEY=

# Azure Translator (client-side fallback — only used if proxy is unavailable)
# Get yours at: https://portal.azure.com → Cognitive Services → Translator
VITE_AZURE_TRANSLATE_KEY=
VITE_AZURE_TRANSLATE_REGION=westeurope

# Stripe (for subscription billing)
# Get yours at: https://dashboard.stripe.com/apikeys
# Test mode keys start with pk_test_ / sk_test_
VITE_STRIPE_PUBLISHABLE_KEY=

# Supabase (already configured — change only for self-hosted)
# VITE_SUPABASE_URL=https://aaefocdqgdgexkcrjhks.supabase.co
# VITE_SUPABASE_ANON_KEY=...

# =============================================================================
# SERVER-SIDE VARIABLES (no VITE_ prefix — only available in Vercel Edge Functions)
# Set these in Vercel Dashboard → Settings → Environment Variables
# =============================================================================

# Google Cloud API Key (used by /api/translate and /api/tts proxy)
# Same key as VITE_GOOGLE_TTS_API_KEY but kept server-side for security
GOOGLE_API_KEY=

# Azure Translator — PRIMARY translation provider (cheapest: 2M chars/month FREE, then $10/1M)
# Get yours at: https://portal.azure.com → Cognitive Services → Translator
AZURE_TRANSLATE_KEY=
AZURE_TRANSLATE_REGION=westeurope

# =============================================================================
# SUPABASE EDGE FUNCTION SECRETS
# Set these via: supabase secrets set KEY=VALUE
# =============================================================================

# Stripe Secret Key — for Checkout Session creation and Customer Portal
# Get at: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret — for verifying webhook signatures
# Get at: https://dashboard.stripe.com/webhooks → select endpoint → Signing secret
# STRIPE_WEBHOOK_SECRET=whsec_...
