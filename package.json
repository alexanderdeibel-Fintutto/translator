{
  "name": "translator",
  "private": true,
  "version": "3.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "build:native": "vite build && npx cap sync",
    "dev:consumer": "vite --config apps/consumer/vite.config.ts",
    "dev:listener": "vite --config apps/listener/vite.config.ts",
    "dev:enterprise": "vite --config apps/enterprise/vite.config.ts",
    "build:consumer": "vite build --config apps/consumer/vite.config.ts",
    "build:listener": "vite build --config apps/listener/vite.config.ts",
    "build:enterprise": "vite build --config apps/enterprise/vite.config.ts",
    "dev:landing": "vite --config apps/landing/vite.config.ts",
    "build:landing": "vite build --config apps/landing/vite.config.ts",
    "dev:school-teacher": "vite --config apps/school-teacher/vite.config.ts",
    "dev:school-student": "vite --config apps/school-student/vite.config.ts",
    "build:school-teacher": "vite build --config apps/school-teacher/vite.config.ts",
    "build:school-student": "vite build --config apps/school-student/vite.config.ts",
    "dev:authority-clerk": "vite --config apps/authority-clerk/vite.config.ts",
    "dev:authority-visitor": "vite --config apps/authority-visitor/vite.config.ts",
    "build:authority-clerk": "vite build --config apps/authority-clerk/vite.config.ts",
    "build:authority-visitor": "vite build --config apps/authority-visitor/vite.config.ts",
    "dev:ngo-helper": "vite --config apps/ngo-helper/vite.config.ts",
    "dev:ngo-client": "vite --config apps/ngo-client/vite.config.ts",
    "build:ngo-helper": "vite build --config apps/ngo-helper/vite.config.ts",
    "build:ngo-client": "vite build --config apps/ngo-client/vite.config.ts",
    "dev:counter-staff": "vite --config apps/counter-staff/vite.config.ts",
    "dev:counter-guest": "vite --config apps/counter-guest/vite.config.ts",
    "build:counter-staff": "vite build --config apps/counter-staff/vite.config.ts",
    "build:counter-guest": "vite build --config apps/counter-guest/vite.config.ts",
    "dev:medical-staff": "vite --config apps/medical-staff/vite.config.ts",
    "dev:medical-patient": "vite --config apps/medical-patient/vite.config.ts",
    "build:medical-staff": "vite build --config apps/medical-staff/vite.config.ts",
    "build:medical-patient": "vite build --config apps/medical-patient/vite.config.ts",
    "dev:conference-speaker": "vite --config apps/conference-speaker/vite.config.ts",
    "dev:conference-listener": "vite --config apps/conference-listener/vite.config.ts",
    "build:conference-speaker": "vite build --config apps/conference-speaker/vite.config.ts",
    "build:conference-listener": "vite build --config apps/conference-listener/vite.config.ts",
    "build:all": "npm run build:consumer && npm run build:listener && npm run build:enterprise && npm run build:landing",
    "build:schools": "npm run build:school-teacher && npm run build:school-student",
    "build:authorities": "npm run build:authority-clerk && npm run build:authority-visitor",
    "build:ngo": "npm run build:ngo-helper && npm run build:ngo-client",
    "build:counter": "npm run build:counter-staff && npm run build:counter-guest",
    "build:medical": "npm run build:medical-staff && npm run build:medical-patient",
    "build:conference": "npm run build:conference-speaker && npm run build:conference-listener",
    "build:markets": "npm run build:schools && npm run build:authorities && npm run build:ngo && npm run build:counter && npm run build:medical && npm run build:conference",
    "dev:artguide": "vite --config apps/artguide-visitor/vite.config.ts",
    "build:artguide": "vite build --config apps/artguide-visitor/vite.config.ts",
    "dev:cityguide": "vite --config apps/cityguide-visitor/vite.config.ts",
    "build:cityguide": "vite build --config apps/cityguide-visitor/vite.config.ts",
    "dev:artguide-whitelabel": "vite --config apps/artguide-whitelabel/vite.config.ts",
    "build:artguide-whitelabel": "vite build --config apps/artguide-whitelabel/vite.config.ts",
    "dev:artguide-portal": "cd apps/artguide-portal && next dev -p 3001",
    "build:artguide-portal": "cd apps/artguide-portal && next build",
    "build:artguide-whitelabel:museum": "tsx scripts/build-whitelabel.ts",
    "build:whitelabel:city": "tsx scripts/build-whitelabel.ts",
    "build:whitelabel:region": "tsx scripts/build-whitelabel.ts",
    "build:guides": "npm run build:artguide && npm run build:artguide-portal"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.1.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capgo/capacitor-bluetooth-low-energy": "^1.1.11",
    "@huggingface/transformers": "^3.8.1",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@sentry/react": "^10.41.0",
    "@supabase/supabase-js": "^2.97.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.8",
    "idb": "^8.0.3",
    "lucide-react": "^0.358.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-ga4": "^2.1.0",
    "react-router-dom": "^6.22.3",
    "sonner": "^1.4.3",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.17",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.35",
    "stripe": "^20.4.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  }
}
